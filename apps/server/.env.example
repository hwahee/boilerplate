# ============================================================================
# Server environment template — copy to `.env` and fill in values.
# Real secrets must NEVER be committed; `.env*` files are gitignored.
#
# Switching between local / development / production requires NO code change:
# only this file (or the environment variables of the deployment) changes.
# Everything here is validated against a schema at boot (src/config.ts) —
# a typo fails fast instead of surfacing as a 3 a.m. runtime error.
#
# NOTE: the mobile app bundle is a PUBLIC artifact. Secrets live here (server
# side) exclusively; anything the app needs a secret for, the server does on
# its behalf.
# ============================================================================

# local | development | production
APP_ENV=local

# HTTP port the server listens on.
PORT=3000

# --- Database -----------------------------------------------------------------
# Driver: `postgres` (default) or `memory` (no external dependency; useful for
# quick local hacking and used automatically by the test suite).
DB_DRIVER=postgres
DATABASE_URL=postgres://app:app_local_password@localhost:5432/app

# Used by docker-compose to provision the Postgres container.
POSTGRES_USER=app
POSTGRES_PASSWORD=app_local_password
POSTGRES_DB=app

# --- CORS ---------------------------------------------------------------------
# Native apps are not subject to CORS; this allowlist exists for future
# browser-based callers (e.g. an admin web console). Comma-separated origins,
# empty = no cross-origin browser access.
CORS_ORIGINS=

# --- Horizontal scaling --------------------------------------------------------
# Pub/sub driver used for cross-instance communication (remote-config push
# fan-out, background jobs): `memory` | `redis`. `memory` only works within a
# single instance; switch to `redis` when running multiple instances behind a
# load balancer.
PUBSUB_DRIVER=memory
# REDIS_URL=redis://localhost:6379

# Role of this process: `web` (HTTP only) | `worker` (background jobs only) | `all`.
SERVER_ROLE=all

# --- Push notifications ---------------------------------------------------------
# `dry-run` logs every send instead of calling a provider (default — works
# with zero credentials). `expo` sends through the Expo push service.
PUSH_DRIVER=dry-run

# --- Admin API -------------------------------------------------------------------
# Bearer token for the /api/admin/* endpoints (version policy & remote config
# management). Leave EMPTY to disable the admin API entirely.
# Generate one with: openssl rand -hex 32
ADMIN_TOKEN=

# --- Graceful shutdown ----------------------------------------------------------
# How long to keep reporting "not ready" before closing the listener, so load
# balancers stop routing traffic to this instance first.
SHUTDOWN_DRAIN_MS=3000
