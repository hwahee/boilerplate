{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    // "bun" is here ONLY for the bun:test import in *.test.ts files — app
    // code must not use Bun APIs (it runs on Hermes).
    "types": ["bun"]
