# ============================================================================
# Environment template — copy to `.env` (or `.env.local`) and fill in values.
# Real secrets must NEVER be committed; `.env*` files are gitignored.
#
# Switching between local / development / production requires NO code change:
# only this file (or the environment variables of the deployment) changes.
# ============================================================================

# local | development | production
APP_ENV=local

# HTTP port the server listens on.
PORT=3000

# --- Database -----------------------------------------------------------------
# Driver: `postgres` (default) or `memory` (no external dependency; useful for
# quick local hacking and used automatically by the test suite).
DB_DRIVER=postgres
DATABASE_URL=postgres://app:app_local_password@localhost:5432/app

# Used by docker-compose to provision the Postgres container.
POSTGRES_USER=app
POSTGRES_PASSWORD=app_local_password
POSTGRES_DB=app

# --- CORS ---------------------------------------------------------------------
# Comma-separated list of allowed origins. Empty = same-origin only.
CORS_ORIGINS=http://localhost:3000

# --- Horizontal scaling --------------------------------------------------------
# Pub/sub driver used for cross-instance communication: `memory` | `redis`.
# `memory` only works within a single instance; switch to `redis` when running
# multiple instances behind a load balancer.
PUBSUB_DRIVER=memory
# REDIS_URL=redis://localhost:6379

# Role of this process: `web` (HTTP only) | `worker` (background jobs only) | `all`.
SERVER_ROLE=all

# --- Graceful shutdown ----------------------------------------------------------
# How long to keep reporting "not ready" before closing the listener, so load
# balancers stop routing traffic to this instance first.
SHUTDOWN_DRAIN_MS=3000
