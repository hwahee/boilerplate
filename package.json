{
  "name": "mobile-fullstack-boilerplate",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "bun run --cwd apps/server dev",
    "dev:mobile": "bun run --cwd apps/mobile start",
    "build:server": "bun run --cwd apps/server build",
    "test": "bun test",
    "typecheck": "bun run --cwd packages/shared typecheck && bun run --cwd apps/server typecheck && bun run --cwd apps/mobile typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run knip && bun test",
    "db:up": "docker compose up -d db",
    "db:migrate": "bun run --cwd apps/server db:migrate",
    "db:seed": "bun run --cwd apps/server db:seed",
    "db:setup": "bun run db:up && bun run --cwd apps/server db:wait && bun run db:migrate && bun run db:seed",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml,js,cjs}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "knip": "^6.23.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
