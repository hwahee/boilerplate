{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    "packages/shared": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/server": {
      "entry": ["src/index.ts", "src/**/*.test.ts", "scripts/*.ts"],
      "project": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "apps/mobile": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["babel-preset-expo"]
    }
  },
  "ignoreBinaries": ["index.js"]
}
